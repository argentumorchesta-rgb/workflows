    {
      "parameters": {
        "jsCode": "// Pre-generation filter ? runs on the batch of pending comments.\n// Tags each with skip / status so a downstream Switch can route:\n//   skip === true  -> set Replied = YES, status = skipped, DO NOT generate\n//   skip === false -> continue to system-prompt builder + Ollama\n\nconst aiPatterns = [\n  /\\bare (you|u) (an? )?(ai|bot|robot|human|real( person| girl| woman)?)\\b/,\n  /\\bis (this|that|she|it) (an? )?(ai|bot|real|fake|generated)\\b/,\n  /\\b(ai|computer)[- ]?generated\\b/,\n  /\\bai (girl|model|account|influencer)\\b/,\n  /\\bchat ?gpt\\b/,\n  /\\bdeepfake\\b/,\n  /\\bnot (a )?real\\b/,\n  /\\bfake (account|profile|person)\\b/,\n  /\\b(are|r) (you|u) fake\\b/,\n  /\\b(you|u) real\\??$/,\n  /\\bdo (you|u) (even )?exist\\b/\n];\n\nreturn $input.all().map(item => {\n  const text = (item.json.Text ?? '').toString().toLowerCase();\n  const isSkip = aiPatterns.some(rx => rx.test(text));\n\n  return {\n    json: {\n      ...item.json,\n      skip: isSkip,\n      status: isSkip ? 'skipped' : 'pending'\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        688,
        256
      ],
      "id": "c39b3752-7fd3-44ae-aad0-1eff9cf880aa",
      "name": "preGenerationFilter"
    },
    {
      "parameters": {
        "jsCode": "// Post-generation guard ? Run Once for All Items\nreturn $input.all().map(item => {\n  const raw = (item.json.output ?? '').toString();\n\n  // Strip markdown fences, then wrapping quotes (straight AND smart)\n  let clean = raw.trim()\n    .replace(/^```[\\s\\S]*?\\n?/, '').replace(/```$/, '')\n    .replace(/^[\"'`]+|[\"'`]+$/g, '')\n    .replace(/^[\\u201C\\u201D\\u2018\\u2019]+|[\\u201C\\u201D\\u2018\\u2019]+$/g, '')\n    .trim();\n\n  const banned = [\n    /\\bas an? (ai|language model|assistant)\\b/i,\n    /\\b(language|ai) model\\b/i,\n    /\\bi (can'?t|cannot|am unable)\\b/i,\n    /\\b(i'?m sorry|i apologize)\\b/i,\n    /\\b(token|api|prompt|json)\\b/i,\n    /<\\/?think>/i, /[{}\\[\\]]/, /```/\n  ];\n\n  const tooLong = clean.length > 280;\n  const empty = clean.length === 0;\n  const isBad = empty || tooLong || banned.some(rx => rx.test(clean));\n\n  return {\n    json: {\n      ...item.json,\n      replyClean: clean,\n      rawReply: raw,\n      status: isBad ? 'review' : 'ok'\n    }\n  };\n});"
      },
