    {
      "parameters": {
        "jsCode": "const tokens = $('Tokens').first().json;\n\nconst tokenMap = {\n  Maeve: tokens.maeveToken,\n  Elara: tokens.elaraToken,\n  Amara: tokens.amaraToken,\n};\n\nconst result = {};\n\nfor (const item of $input.all()) {\n  const {\n    Name,\n    Personality,\n    Birthday,\n    Height,\n    Country,\n    Religion,\n    Hair,\n    Eyes,\n    Skin,\n    Breasts,\n    Age\n  } = item.json;\n\n  result[Name] = {\n    Personality,\n    Birthday,\n    Height,\n    Country,\n    Religion,\n    Hair,\n    Eyes,\n    Skin,\n    Breasts,\n    Age,\n    Token: tokenMap[Name] ?? null,\n  };\n}\n\nreturn [\n  {\n    json: result\n  }\n];"
      },
