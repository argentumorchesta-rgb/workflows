    {
      "parameters": {
        "jsCode": "return $('Start').first().json.updateStatus1_allItems.map(({ json }) => {\n  let ext;\n  if (json.Id.startsWith(\"REEL_\")) {\n    ext = \".mp4\";\n  } else if (json.Id.startsWith(\"IMAGE_\")) {\n    ext = \".png\";\n  } else {\n    throw new Error(`Unexpected Id prefix: ${json.Id}`);\n  }\n  return {\n    json: {\n      file_name: json.Id + ext,\n    }\n  };\n});"
      },
