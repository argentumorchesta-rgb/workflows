    {
      "parameters": {
        "jsCode": "// n8n API returns { data: [...workflows], nextCursor: null|string }\nconst res = $input.first().json;\nconst workflows = res.data || [];\nconst config = $('Config').first().json;\n\nif (workflows.length === 0) {\n  throw new Error('No workflows returned. Check n8nBaseUrl and n8nApiKey in the Config node.');\n}\n\nconsole.log(`Found ${workflows.length} workflows to back up.`);\n\n// Attach config to each workflow item for downstream access\nreturn workflows.map(wf => ({\n  json: { ...wf, _config: config }\n}));"
      },
