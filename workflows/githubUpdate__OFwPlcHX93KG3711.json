    {
      "parameters": {
        "jsCode": "// Prepare per-workflow metadata for GitHub API calls\nconst wf = $input.first().json;\nconst config = wf._config;\n\n// Sanitise workflow name for use as a filename\nconst safeName = (wf.name || 'unnamed')\n  .replace(/[^a-zA-Z0-9._-]/g, '_')\n  .replace(/_+/g, '_')\n  .replace(/^_|_$/, '');\n\nconst filename = `${safeName}__${wf.id}.json`;\nconst githubFilePath = `workflows/${filename}`;\n\n// Strip internal _config before saving to GitHub\nconst { _config, ...cleanWf } = wf;\n\nreturn [{\n  json: {\n    workflowId:      wf.id,\n    workflowName:    wf.name,\n    workflowJson:    JSON.stringify(cleanWf, null, 2),\n    filename,\n    githubFilePath,\n    githubOwner:     config.githubOwner,\n    githubRepo:      config.githubRepo,\n    githubBranch:    config.githubBranch\n  }\n}];"
      },
